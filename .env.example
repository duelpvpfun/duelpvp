# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# NEVER commit `.env` or share these values.

# Helius mainnet RPC (includes your API key). Used for deploy + frontend.
MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Phantom-exported private key (base58 string). Used once to derive the
# authority keypair file; never logged or committed.
PHANTOM_PRIVATE_KEY=
